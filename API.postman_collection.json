{
	"info": {
		"_postman_id": "users-api-collection",
		"name": "Ecommerce Backend API - Full Collection",
		"description": "Complete collection for Auth, Users, Products, Orders, and Cart API with JWT. Set {{token}} from Login response (data field) for protected routes. Set {{userId}}, {{addrId}}, {{productId}}, and {{orderId}} as needed.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:3000" },
		{ "key": "token", "value": "" },
		{ "key": "userId", "value": "" },
		{ "key": "addrId", "value": "" },
		{ "key": "productId", "value": "" },
		{ "key": "orderId", "value": "" }
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"SecurePass123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/auth/register",
						"description": "Register a new user. Required: name, email, password. Email must be unique. Password minimum 8 characters."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    if (json.data) {",
									"        pm.collectionVariables.set('token', json.data);",
									"        console.log('Token saved:', json.data);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"SecurePass123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/auth/login",
						"description": "Login with email and password. Returns JWT in data field. Token is automatically saved to collection variable 'token' for protected requests."
					},
					"response": []
				},
				{
					"name": "Verify Email",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/auth/verify-email/sample-code-here",
						"description": "Verify user email using a verification code sent by email. Replace 'sample-code-here' with the actual verification code."
					},
					"response": []
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/auth/forgot-password",
						"description": "Trigger password reset email. Always returns a generic success message for security. Required: email."
					},
					"response": []
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"password\": \"NewSecurePass123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/auth/reset-password/sample-reset-token",
						"description": "Reset password using a reset token from the email. Replace 'sample-reset-token' with the actual token. Required body: password."
					},
					"response": []
				},
				{
					"name": "Admin Login (Step 1 - Send 2FA Code)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"AdminPass123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/auth/admin/login",
						"description": "Admin login step 1. Verifies credentials and sends a 2FA code to the admin email if valid. No JWT is returned here."
					},
					"response": []
				},
				{
					"name": "Admin Verify 2FA (Step 2 - Get Admin Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    if (json.data && json.data.token) {",
									"        pm.collectionVariables.set('token', json.data.token);",
									"        console.log('Admin token saved:', json.data.token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@example.com\",\n    \"code\": \"123456\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/auth/admin/verify-2fa",
						"description": "Admin login step 2. Verify the 2FA code sent to the admin email. On success returns a JWT in data.token, which is saved automatically to the 'token' collection variable."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/auth/logout",
						"description": "Logout current user. This simply invalidates the session on the backend side if applicable; the client should also clear the stored token."
					},
					"response": []
				},
				{
					"name": "Me (Get Current User)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/auth/me",
						"description": "Get the currently authenticated user's data using the JWT token."
					},
					"response": []
				}
			],
			"description": "Authentication: register, login, verify email, password reset, admin 2FA login, logout, and fetching the current user. Login and admin 2FA endpoints return JWTs used in the Authorization header."
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/users/profile",
						"description": "Get current user's profile. Requires valid JWT (Authorization: Bearer token). Returns user data without password."
					},
					"response": []
				},
				{
					"name": "Update Profile",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane@example.com\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/profile/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "profile", "{{userId}}"]
						},
						"description": "Update own profile. Only the logged-in user can update their own profile (userId in URL must match token). Send only fields to update: name, email, etc."
					},
					"response": []
				},
				{
					"name": "Change Password",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"currentPassword\": \"SecurePass123\",\n    \"newPassword\": \"NewSecurePass123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/change-password/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "change-password", "{{userId}}"]
						},
						"description": "Change password. Only the logged-in user can change their own password (userId in URL must match token). Required: currentPassword, newPassword."
					},
					"response": []
				},
				{
					"name": "Add Address",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"street\": \"123 Main St\",\n    \"city\": \"New York\",\n    \"zip\": \"10001\",\n    \"country\": \"USA\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/addresses/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "addresses", "{{userId}}"]
						},
						"description": "Add a new address to user's profile. Only the logged-in user can add addresses to their own profile (userId in URL must match token). Required: street, city, zip, country."
					},
					"response": []
				},
				{
					"name": "Update Address",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"street\": \"456 Oak Ave\",\n    \"city\": \"Los Angeles\",\n    \"zip\": \"90001\",\n    \"country\": \"USA\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/addresses/{{addrId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "addresses", "{{addrId}}"]
						},
						"description": "Update an existing address. Requires JWT. Send only fields to update: street, city, zip, country."
					},
					"response": []
				},
				{
					"name": "Delete Address",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{baseUrl}}/users/addresses/{{addrId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "addresses", "{{addrId}}"]
						},
						"description": "Delete an address by address ID. Requires JWT."
					},
					"response": []
				},
				{
					"name": "Get All Users (Admin Only)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/users",
						"description": "Get all users. Requires valid JWT with admin role (Authorization: Bearer token)."
					},
					"response": []
				},
				{
					"name": "Update User Role (Admin Only)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role\": \"admin\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}/role",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{userId}}", "role"]
						},
						"description": "Update user role. Requires admin role. Valid roles: 'customer', 'admin'."
					},
					"response": []
				},
				{
					"name": "Delete User (Admin Only)",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{baseUrl}}/users/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["users", "{{userId}}"]
						},
						"description": "Delete user by ID. Requires admin role (checkPermissions)."
					},
					"response": []
				}
			],
			"description": "Users CRUD operations. Most endpoints require Authorization: Bearer <token>. Profile/Password/Address operations only for own user. Admin operations require admin role."
		},
		{
			"name": "Products",
			"item": [
				{
					"name": "Get All Products",
					"request": {
						"method": "GET",
						"header": [],
						"url": "{{baseUrl}}/product",
						"description": "Get all active products. No authentication required. Returns products sorted by creation date (newest first)."
					},
					"response": []
				},
				{
					"name": "Get Product By ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/product/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["product", "{{productId}}"]
						},
						"description": "Get a product by MongoDB _id. No authentication required."
					},
					"response": []
				},
				{
					"name": "Get Products By Category",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/product/category/electronics",
							"host": ["{{baseUrl}}"],
							"path": ["product", "category", "electronics"]
						},
						"description": "Get all products by category. Valid categories: 'electronics', 'clothing', 'food'. No authentication required."
					},
					"response": []
				},
				{
					"name": "Create Product (Admin Only)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Laptop\",\n    \"description\": \"High-performance laptop\",\n    \"price\": 999.99,\n    \"category\": \"electronics\",\n    \"stock\": 50,\n    \"images\": [\"https://example.com/image1.jpg\"]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/product",
						"description": "Create a new product. Requires admin role. Required: name, description, price, category, stock. Optional: images (array of strings). Valid categories: 'electronics', 'clothing', 'food'."
					},
					"response": []
				},
				{
					"name": "Update Product (Admin Only)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Laptop\",\n    \"price\": 899.99,\n    \"stock\": 30\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/product/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["product", "{{productId}}"]
						},
						"description": "Update a product. Requires admin role. Send only fields to update: name, description, price, category, stock, images, isActive."
					},
					"response": []
				},
				{
					"name": "Delete Product (Admin Only)",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{baseUrl}}/product/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["product", "{{productId}}"]
						},
						"description": "Delete a product by ID. Requires admin role."
					},
					"response": []
				},
				{
					"name": "Add Product Rating",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"rating\": 5,\n    \"comment\": \"Great product!\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/product/{{productId}}/rating",
							"host": ["{{baseUrl}}"],
							"path": ["product", "{{productId}}", "rating"]
						},
						"description": "Add a rating to a product. Requires JWT. Required: rating (1-5). Optional: comment. Note: User ID is typically extracted from token automatically."
					},
					"response": []
				}
			],
			"description": "Products CRUD operations. Get endpoints are public. Create/Update/Delete require admin role. Add rating requires authentication."
		},
		{
			"name": "Orders",
			"item": [
				{
					"name": "Create Order",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const json = pm.response.json();",
									"    if (json.data && json.data._id) {",
									"        pm.collectionVariables.set('orderId', json.data._id);",
									"        console.log('Order ID saved:', json.data._id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"items\": [\n        { \"product\": \"{{productId}}\", \"quantity\": 2 }\n    ],\n    \"shippingAddress\": {\n        \"fullName\": \"John Doe\",\n        \"phone\": \"+1234567890\",\n        \"country\": \"USA\",\n        \"city\": \"New York\",\n        \"street\": \"123 Main St\"\n    },\n    \"paymentMethod\": \"credit\",\n    \"notes\": \"Please deliver in the morning\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/order",
						"description": "Create a new order. Requires JWT. Required: items (array of { product: productId, quantity }), shippingAddress (fullName, phone, country, city, street?), paymentMethod ('credit'|'paypal'|'simulated'). Optional: notes."
					},
					"response": []
				},
				{
					"name": "Get My Orders",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/order/my-orders",
						"description": "Get all orders for the logged-in user. Requires JWT."
					},
					"response": []
				},
				{
					"name": "Get Order By ID",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{baseUrl}}/order/{{orderId}}",
							"host": ["{{baseUrl}}"],
							"path": ["order", "{{orderId}}"]
						},
						"description": "Get a single order by MongoDB _id. Requires JWT."
					},
					"response": []
				},
				{
					"name": "Get All Orders (Admin Only)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/order",
						"description": "Get all orders. Requires admin role."
					},
					"response": []
				},
				{
					"name": "Update Order Status (Admin Only)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"orderStatus\": \"processing\",\n    \"trackingNumber\": \"TRK123456789\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/order/{{orderId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["order", "{{orderId}}", "status"]
						},
						"description": "Update order status. Requires admin role. Valid orderStatus: 'pending', 'processing', 'shipped', 'delivered', 'cancelled'. Optional: trackingNumber."
					},
					"response": []
				},
				{
					"name": "Cancel Order",
					"request": {
						"method": "PUT",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{baseUrl}}/order/{{orderId}}/cancel",
							"host": ["{{baseUrl}}"],
							"path": ["order", "{{orderId}}", "cancel"]
						},
						"description": "Cancel an order. Requires JWT. Typically only the order owner can cancel."
					},
					"response": []
				}
			],
			"description": "Orders: create (auth), get my orders (auth), get by ID (auth), get all (admin), update status (admin), cancel (auth)."
		},
		{
			"name": "Cart",
			"item": [
				{
					"name": "Get Cart",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/cart",
						"description": "Get the current user's cart. Requires JWT (Authorization: Bearer token)."
					},
					"response": []
				},
				{
					"name": "Add Product to Cart",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"productID\": \"{{productId}}\",\n    \"quantity\": 1\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/cart",
						"description": "Add a product to the cart or increase quantity if already present. Requires JWT. Required: productID, quantity (default 1)."
					},
					"response": []
				},
				{
					"name": "Update Product Quantity",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"quantity\": 2\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{baseUrl}}/cart/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["cart", "{{productId}}"]
						},
						"description": "Update the quantity of a product in the cart. Requires JWT. Required body: quantity."
					},
					"response": []
				},
				{
					"name": "Delete Product from Cart",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": {
							"raw": "{{baseUrl}}/cart/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["cart", "{{productId}}"]
						},
						"description": "Remove a product from the cart. Requires JWT."
					},
					"response": []
				},
				{
					"name": "Clear Cart",
					"request": {
						"method": "DELETE",
						"header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
						"url": "{{baseUrl}}/cart",
						"description": "Remove all products from the cart. Requires JWT."
					},
					"response": []
				},
				{
					"name": "Sync Cart",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"items\": [\n        { \"product\": \"{{productId}}\", \"quantity\": 1 }\n    ]\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": "{{baseUrl}}/cart/sync",
						"description": "Merge the cart stored in localStorage with the user's cart in the database (e.g. after login). Body: items array of { product, quantity }."
					},
					"response": []
				}
			],
			"description": "Cart: get cart, add/update/remove items, clear cart, sync cart from localStorage. All except Sync require JWT; Sync may be called with or without token depending on implementation."
		}
	]
}